{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./",
        "skipLibCheck": true
    },
    "include": [
        "server.ts",
        "controllers/**/*.ts",
        "routes/**/*.ts",
        "services/**/*.ts",
        "middleware/**/*.ts",
        "types/**/*.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
